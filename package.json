  "enabledApiProposals": [
    "chatProvider",
    "defaultChatParticipant",
    "chatParticipantAdditions",
    "chatParticipantPrivate",
    "textSearchProvider",
    "textSearchProvider2",
    "fileSearchProvider2",
    "aiTextSearchProvider"
  ],
  "workspaces": [
    "./webview/main"
  ],
  "private": true,
  "scripts": {
    "build": "npm run build:contributes && npm run build:type:code-node && tsx --env-file=dev.env ./script/build.ts ",
    "build:prod": "rimraf ./dist && npm run build -- --prod",
    "copytovscode": "rimraf ./lib/vscode/extensions/shenghuabi && cpx \"./dist/**/*\" ./lib/vscode/extensions/shenghuabi",
    "xvscode:prepublish": "npm run package",
    "watch": " npm run build:contributes && npm run build:type:code-node && tsx --env-file=dev.env ./script/build.ts --watch",
    "watch:run": "npm run watch",
    "lint": "eslint --fix ./src  && prettier ./src --write && eslint --fix ./webview/main/src  && prettier ./webview/main/src --write",
    "watch:test": "rimraf ./test-dist  && tsx ./script/test.esbuild.ts ",
    "pretest": "npm run watch:test -- --build",
    "test": "vscode-test",
    "coverage": "vscode-test --coverage",
    "local-publish": "vsce package --skip-license",
    "vs-publish": "vsce publish --skip-license",
    "copy-assets": "rimraf ./build && node ./script/build.js && cpx \"dist/**/*\" ./build/dist && cpx \"webview/main-view/dist/**/*\" ./build/webview/main-view/dist && cpx ./LICENSE ./build && cpx \"package.nls.*\" ./build && cpx ./README.md ./build && cpx \"./l10n/**/*\" ./build/l10n && cpx \"docs/icon/**/*\" ./build/docs/icon",
    "build:contributes": "tsx ./script/metadata/contributes.ts",
    "change:vscode": "code-recycle --cwd ./lib/vscode ./script/change-vscode/index.ts && tsx ./script/change-vscode/remove-unuse-import.ts",
    "update:product": "tsx ./script/update-product.ts",
    "build:extension": "tsx ./script/build-extension",
    "build:common-package": "tsx ./script/build-common-package.ts",
    "move:extension": "tsx ./script/move-extension.ts --capture",
    "build:vscode-output": "tsx ./script/build-output.ts",
    "move:extension:local": "tsx ./script/move-extension.ts",
    "change:vfs": "code-recycle --cwd ./src ./script/change-vfs.ts",
    "build:type:code-node": "dts-bundle-generator ./src/declaration/code-node.ts --project ./tsconfig.code-node.type.json -o dist/code-node.d.ts --external-inlines zod --external-inlines zod-to-json-schema --external-inlines openai    --no-check --no-banner --inline-declare-externals --export-referenced-types false",
    "build:plugin-sdk": "tsx ./script/build-sdk.ts",
    "publish:plugin-sdk": "npm run build:plugin-sdk && npm publish ./plugin-sdk-dist",
    "install:all": "npm i --force && cd webview/main && npm i",
    "update": "ng update @angular/core@21 @angular/cdk@21 @angular/material@21 @angular/cli@21 --force --allow-dirty",
    "check-version":"tsx ./script/check-version-branch.ts"
  },
