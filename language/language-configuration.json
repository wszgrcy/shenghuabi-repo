{
  "wordPattern": {
    "pattern": "\\p{Script=Hani}|(\\p{L}(?<!\\p{Script=Hani}))+|(((?:[\\p{P}\\p{S}](?<![，。？！；：、“”‘’【】\\[\\]<>《》（）〔〕·\\-~…—]))+)(.(?<=(\\p{L}|\\p{N})))+)+",
    "flags": "gu"
  },
  "autoClosingPairs": [
    { "open": "{", "close": "}" },
    { "open": "[", "close": "]" },
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" },
    { "open": "'", "close": "'" },
    { "open": "<", "close": ">" },
    { "open": "《", "close": "》" },
    { "open": "（", "close": "）" },
    { "open": "【", "close": "】" },
    { "open": "“", "close": "”" },
    { "open": "‘", "close": "’" },
    { "open": "〔", "close": "〕" },
    { "open": "「", "close": "」" }
  ],
  "brackets": [
    ["{", "}"],
    ["[", "]"],
    ["(", ")"],
    ["\"", "\""],
    ["'", "'"],
    ["<", ">"],
    ["《", "》"],
    ["（", "）"],
    ["【", "】"],
    ["“", "”"],
    ["‘", "’"],
    ["〔", "〕"],
    ["「", "」"]
  ],
  "onEnterRules": []
}
